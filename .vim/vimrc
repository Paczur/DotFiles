"SYNTAX {{{
function! s:syntax_query() abort
  for id in synstack(line("."), col("."))
    echo synIDattr(id, "name")
  endfor
endfunction
command! SyntaxQuery call s:syntax_query()
au! Syntax markdown source syntax/markdown.vim
au! Syntax html source syntax/html.vim
filetype on
filetype plugin on
filetype indent on
syntax on
autocmd Syntax * syn region Important start="[^ ]*TODO" end="\n" containedin=.*omment.*
autocmd Syntax * syn region Important start="!:" end=":!\|\n" containedin=.*omment.*
autocmd Syntax * syn match comment "\v(^#include.*\n)+" fold
autocmd Syntax * syn match comment "\v(^import.*\n)+" fold
autocmd Syntax * syn region CommentBlock start="/\*" end="\*/" transparent keepend extend fold
autocmd Syntax * syn match comment "\v(^\s*//.*\n)+" fold
autocmd Syntax * set formatoptions=rqn2jc
"}}}

