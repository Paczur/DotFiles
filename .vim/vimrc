"FOLDS {{{
set foldlevel=0
set foldnestmax=0
function! FoldText()
    let line = substitute(substitute(
\              substitute(substitute(
\              substitute(getline(v:foldstart),
\                         '{\+', '', ''),
\                         '^"\s*', '', ''),
\                         '/\*\s*\(.*\)\s*\*/', '\=submatch(1)', ''),
\                         '^\s*//\s*', '', ''), '^#\s*', '', '')
    let lines_count = v:foldend - v:foldstart + 1
    let lines_count_text = printf("%10s", lines_count . ' lines')
    let foldchar = matchstr(&fillchars, 'fold:\zs.')
    let foldtextstart = strpart(line, 0, (winwidth(0)*2)/3)
    let foldtextend = lines_count_text . repeat(foldchar, 8)
    let foldtextlength = strlen(substitute(foldtextstart . foldtextend,
\                                          '.', 'x', 'g')) + &foldcolumn
    return foldtextstart . repeat(foldchar, winwidth(0)-foldtextlength) . foldtextend
endfunction
function! FoldColumn()
  if &foldnestmax == 0
    set foldcolumn=0
  elseif &foldnestmax == 1
    set foldcolumn=2
  else
    let &foldcolumn=&foldnestmax*2+1
  endif
endfunction

set foldexpr=FoldMethod(v:lnum)
autocmd FileType c set foldmethod=syntax
autocmd FileType c set foldnestmax=1
autocmd FileType java set foldmethod=syntax
autocmd FileType java set foldlevel=1
autocmd FileType java set foldnestmax=2
autocmd FileType css set foldmethod=marker
autocmd FileType css set foldnestmax=1
autocmd FileType html set foldmethod=indent
autocmd FileType html set foldlevel=5
autocmd FileType htmldjango set foldmethod=indent
autocmd FileType htmldjango set foldlevel=5
autocmd FileType python set foldmethod=indent
autocmd FileType python set foldnestmax=1
autocmd FileType vim set foldmethod=marker
autocmd FileType vim set foldnestmax=1
autocmd FileType i3config set foldmethod=marker
autocmd FileType i3config set foldnestmax=2

autocmd FileType * call FoldColumn()
autocmd FileType * set foldtext=FoldText()

autocmd FileType htmldjango set foldcolumn=0
"}}}

