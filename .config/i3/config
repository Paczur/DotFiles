# i3 config file (v4)

# VARIABLES {{{
set $mod Mod1
set $y #f3f36e
set $g #333333
set $d #111111
set $w #f3f3f3
set $ws1 "1:Ⅰ"
set $ws2 "2:Ⅱ"
set $ws3 "3:Ⅲ"
set $ws4 "4:"
set $ws5 "5:"
set $ws6 "6:󱕴"
set $ws7 "7:Ⅶ"
set $ws8 "8:Ⅷ"
set $ws9 "9:Ⅸ"
set $ws10 "10:"
set $m1 "eDP1"
set $m2 "HDMI1"
set $system ""
set $mpv ""
set $window ""
set $scrot_path "/home/paczur/Multimedia/Pictures/Screenshots/Scrot/%d-%m-%Y_%H-%M-%S_$wx$h.png"
#}}}

# WORKSPACES {{{
workspace $ws1 output $m1
workspace $ws2 output $m1
workspace $ws3 output $m1
workspace $ws4 output $m1
workspace $ws5 output $m1
workspace $ws6 output $m1
workspace $ws7 output $m2
workspace $ws8 output $m2
workspace $ws9 output $m2
workspace $ws10 output $m1

assign [class="^Pavucontrol$"] $ws10
assign [class="^QjackCtl$"] $ws10
for_window [title="alsamixer"] move to workspace $ws10
assign [class="^TelegramDesktop$"] $ws5
assign [class="^librewolf$"] $ws4
assign [class="^MuPDF$"] $ws3
assign [class="^KeePassXC$"] $ws6

# KEYBINDS {{{
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+b split h
bindsym $mod+v split v

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10
#}}}
#}}}

# BAR {{{
bar {
  output $m1
    output $m2
    tray_output none
    position top
    separator_symbol " "
    status_command i3blocks
    workspace_buttons yes
    strip_workspace_numbers yes
    padding 3 0
    workspace_min_width 40
    i3bar_command i3bar
# COLORS {{{
    colors {
        #class             border background text
        active_workspace   $g     $g         $w
        focused_workspace  $w     $w         $d
        inactive_workspace $g     $g         $w
        urgent_workspace   $y     $y         $d
        binding_mode       $w     $d         $w
        background $d
        statusline $d
    }
}
#}}}
#}}}

# MODES {{{
bindsym $mod+w mode $window
bindsym $mod+c mode $mpv
bindsym $mod+s mode $system

# SYSTEM {{{
mode $system {
  bindsym w exec "notify-send 'Rebooting to windows';sudo grub-reboot 2; sudo reboot"
    bindsym l exec "notify-send 'Rebooting';sudo grub-reboot 0; sudo reboot"
    bindsym s mode default; exec "notify-send 'Suspending'; sudo suspend"
    bindsym Shift+s exec "notify-send 'Powering off'; sudo shutdown"

    bindsym Escape mode "default"
    bindsym $mod+s mode "default"
    bindsym $mod+w mode $window
    bindsym $mod+c mode $mpv
}
#}}}

# WINDOW {{{
mode $window {
  bindsym 1 move container to workspace $ws1
    bindsym 2 move container to workspace $ws2
    bindsym 3 move container to workspace $ws3
    bindsym 4 move container to workspace $ws4
    bindsym 5 move container to workspace $ws5
    bindsym 6 move container to workspace $ws6
    bindsym 7 move container to workspace $ws7
    bindsym 8 move container to workspace $ws8
    bindsym 9 move container to workspace $ws9
    bindsym 0 move container to workspace $ws10
    bindsym q kill
    bindsym f fullscreen toggle
    bindsym g floating toggle
    bindsym a focus parent
    bindsym z focus child
    bindsym x layout toggle stacking split
    bindsym h resize shrink width 5 px or 5 ppt
    bindsym j resize grow height 5 px or 5 ppt
    bindsym k resize shrink height 5 px or 5 ppt
    bindsym l resize grow width 5 px or 5 ppt
    bindsym Shift+h move left
    bindsym Shift+j move down
    bindsym Shift+k move up
    bindsym Shift+l move right

    bindsym Escape mode "default"
    bindsym $mod+w mode "default"
    bindsym $mod+s mode $system
    bindsym $mod+c mode $mpv
}
#}}}

# MPV {{{
mode $mpv {
  bindsym f exec "echo 'cycle pause' | socat - /tmp/mpvsocket"
    bindsym d exec "echo 'playlist_next' | socat - /tmp/mpvsocket"
    bindsym a exec "echo 'playlist_prev' | socat - /tmp/mpvsocket"
    bindsym w exec "echo 'add volume 2' | socat - /tmp/mpvsocket && pkill -SIGRTMIN+10 i3blocks"
    bindsym s exec "echo 'add volume -2' | socat - /tmp/mpvsocket && pkill -SIGRTMIN+10 i3blocks"
    bindsym q exec "echo 'quit' | socat - /tmp/mpvsocket && pkill -SIGRTMIN+10 i3blocks; rm /tmp/mpvsocket"
    bindsym Escape mode "default"
    bindsym $mod+c mode "default"
    bindsym $mod+s mode $system
    bindsym $mod+w mode $window
}
#}}}
#}}}

# EYECANDY {{{
font pango: CodeNewRoman Nerd Font Propo, IPAexGothic 14

default_floating_border pixel 4
default_border pixel 2
for_window [class="^Tamagotchi$"] floating enable
for_window [floating_from="user"] border pixel 4
for_window [tiling_from="user"] border pixel 2
hide_edge_borders both

smart_gaps on
gaps inner 15
gaps top -5

# COLORS {{{
#class                  title_border bg text indicator border
client.focused          $w           $d $w   $w        $w
client.focused_inactive $g           $d $w   $g        $g
client.unfocused        $g           $d $w   $g        $g
client.urgent           $y           $d $d   $y        $y
client.background $g
#}}}
#}}}

# USABILITY {{{
popup_during_fullscreen leave_fullscreen
focus_on_window_activation none
no_focus [tiling]
mouse_warping none
focus_follows_mouse no
floating_modifier $mod

# KEYBINDS {{{
bindsym $mod+Return exec mlterm
bindsym $mod+Shift+q kill
bindsym $mod+d exec dmenu_run -f -i -fn "Code New Roman 14" -nb '#000000' -nf '#ffffff' -sb '#333333' -sf '#ffffff'
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+r restart
bindsym --release $mod+p exec scrot -s -q 100 -e "xclip -selection clipboard -t image/png -i $scrot_path" $scrot_path
bindsym XF86MonBrightnessDown exec xbacklight -dec 2 && pkill -SIGRTMIN+11 i3blocks
bindsym XF86MonBrightnessUp exec xbacklight -inc 2 && pkill -SIGRTMIN+11 i3blocks
#}}}
#}}}
