command=~/.config/i3blocks/$BLOCK_NAME
separator_block_width=1
separator=false
border_left=10
border_right=10
border_top=0
border_bottom=0
background=#333333
border=#333333
color=#ffffff
markup=cairo

[mpv-volume]
label= 
interval=30
signal=10

[emerge-update]
interval=0
signal=10
command=[ -f "/home/paczur/Temp/update" ] && echo "" || echo ""

[brightness]
label= 
interval=-1
signal=11
command=x=$(xbacklight -get); if [ -n "$x" ]; then echo ${x%.*}%; fi

[net]
interval=60

[battery]
interval=60

[cpu]
label= 
interval=5

[date]
label= 
command=date '+%d-%m-%Y'
interval=60

[time]
label= 
command=date '+%H:%M:%S'
interval=1
