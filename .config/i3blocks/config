[cpu]
label= 
#background=#ff0000
#border=#ff0000
interval=5

#[battery]
#color=#00ff00
#interval=60

[gpu]
label= 
#command=echo $(nvidia-smi --format=csv --query-gpu=utilization.gpu | sed '1d' | rev | cut -c3- | rev)%
