Xft.dpi:        96
Xft.antialias:  true
Xft.rgba:       rgb
Xft.hinting:    true
Xft.hintstyle:  hintfull
Xft.autohint:   false
Xft.lcdfilter:  lcddefault

*geometry: 400x400
*font: xft:CodeNewRoman Nerd Font Mono:size=14
*savelines: 16384
*ScrollBar: false
*scrollBar: false
*termName: xterm-256color
*BellIsUrgent: true
*cursorBlink: true

*cursorColor: #f3f3f3
*pointerColor: #f3f3f3
*Background: #333333
*Foreground: #f3f3f3
*background: #333333
*foreground: #f3f3f3
*color0:  #111111
*color1:  #f36e6e
*color2:  #6ef36e
*color3:  #f3f36e
*color4:  #6e6ef3
*color5:  #f36ef3
*color6:  #6ef3f3
*color7:  #aaaaaa
*color8:  #333333
*color9:  #f36e6e
*color10: #6ef36e
*color11: #f3f36e
*color12: #6e6ef3
*color13: #f36ef3
*color14: #6ef3f3
*color15: #f3f3f3
