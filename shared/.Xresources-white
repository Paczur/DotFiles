!red
*.color1:  #b32e2e
*.color9:  #b32e2e
!green
*.color2:  #0e930e
*.color10: #0e930e
!yellow
*.color3:  #93930e
*.color11: #93930e
!blue
*.color4:  #3e3ed3
*.color12: #3e3ed3
!cyan
*.color5:  #1ea3a3
*.color13: #1ea3a3
!magenta
