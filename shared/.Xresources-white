Xft.dpi:        96
Xft.antialias:  true
Xft.rgba:       rgb
Xft.hinting:    true
Xft.hintstyle:  hintfull
Xft.autohint:   false
Xft.lcdfilter:  lcddefault

*geometry: 400x400
*font: xft:CodeNewRoman Nerd Font Mono:size=14
*savelines: 16384
*ScrollBar: false
*scrollBar: false
*termName: xterm-256color
*BellIsUrgent: true
*cursorBlink: true

*.cursorColor: #000000
*.pointerColor: #000000
*.foreground: #000000
*.background: #eeeeee
!black
