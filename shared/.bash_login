#!/bin/env bash
. /usr/local/bin/system/path
. ~/.bashrc
export PATH
t="$(tty | sed 's/.*\/tty//g')"
case "$t" in
  "1")
  wm="/usr/bin/i3"
  ;;
  *)
  wm=""
  ;;
esac
set bell_style none
if [ -n "$wm" ]; then
  cat ~/.config/i3/* > ~/.config/i3/config
  exec startx ~/.xinitrc "$wm" -- "vt$t"
fi
clear
