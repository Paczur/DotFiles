#!/bin/env/bash
. /home/paczur/Scripts/system/path
. ~/.bashrc
export PATH
t="$(tty | sed 's/.*\/tty//g')"
case "$t" in
  "1")
  wm="/usr/bin/awm"
  ;;
  *)
  wm=""
  ;;
esac
set bell_style none
echo "$wm" > /home/paczur/Build/send
if [ -n "$wm" ]; then
  exec startx ~/.xinitrc "$wm" -- "vt$t"
fi
clear
