"FOLDS {{{
set foldlevel=0
set foldnestmax=10
set foldcolumn=0
function! Common_FoldText()
  let foldtext = substitute(
        \    substitute(substitute(substitute(
        \    substitute(getline(v:foldstart),
        \    '^"\+\s*',                '',                                  ''),
        \    '\s*/\*\s*',   '',                     ''),
        \    '\s*\*/\s*',   '',                     ''),
        \    '^\s*//\s*',            '',                                  ''),
        \    '^\s\+',                '\=repeat("─",strlen(submatch(0)))', '')
  if foldtext == ""
    return getline(v:foldstart)
  endif
  return foldtext
endfunction
function! C_FoldText()
  let foldtext = substitute(Common_FoldText(),
        \ '\s*\\$',             '',                                  '')
  if foldtext == ""
    return getline(v:foldstart)
  endif
  return foldtext
endfunction
function! FoldText()
  let foldtext = substitute(Common_FoldText(),
        \ '^#\s*',              '',                                  '')
  if foldtext == ""
    return getline(v:foldstart)
  endif
  return foldtext
endfunction

set foldexpr=FoldMethod(v:lnum)
let javaScript_fold=1
autocmd FileType c          set foldmethod=syntax
