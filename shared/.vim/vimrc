" WORK {{{
function! Test()
  let l:output = system('change ' . shellescape(expand("%:p")) . ' test')
  execute ':edit ' . l:output
endfunction

function! Body()
  let l:output = system('change ' . shellescape(expand("%:p")) . ' body')
  execute ':edit ' . l:output
endfunction

function! ApiPrivate()
  let l:output = system('change ' . shellescape(expand("%:p")) . ' api-private')
  execute ':edit ' . l:output
endfunction

function TraceInfo()
  :r !next-trace
  :normal ITRACE_INFO_UID(MH.
  :normal $a, "", NO_ARG);
  :normal 10h
endfunction

function TraceBus()
  :r !next-trace
  :normal ITRACE_BUS_WH_UID(MH.
  :normal $a, CM_NULL, , , "", NO_ARG);
  :normal 15h
endfunction

if g:work == 1
  command T call Test()
  command B call Body()
  command A call ApiPrivate()
  command TI call TraceInfo()
  command TB call TraceBus()
endif
" }}}
