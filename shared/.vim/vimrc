"FOLDS {{{
set foldlevel=0
set foldnestmax=0
set foldcolumn=0
function! C_FoldText()
  let foldtext = substitute(substitute(
        \    substitute(substitute(
        \    substitute(substitute(getline(v:foldstart),
        \ '{\+\s*$',              '',                                ''),
        \ '^"\s*',              '',                                  ''),
        \ '/\*\s*\(.*\)\s*\*/', '\=submatch(1)',                     ''),
        \ '^\s*//\s*',          '',                                  ''),
        \ '\s*\\$',             '',                                  ''),
        \ '^\s\+',              '\=repeat("-",strlen(submatch(0)))', '')
  if foldtext == ""
    return getline(v:foldstart)
  endif
  return foldtext
endfunction
function! FoldText()
  let foldtext = substitute(substitute(
        \    substitute(substitute(
        \    substitute(substitute(getline(v:foldstart),
        \ '{\+\s*$',              '',                                ''),
        \ '^"\s*',              '',                                  ''),
        \ '/\*\s*\(.*\)\s*\*/', '\=submatch(1)',                     ''),
        \ '^\s*//\s*',          '',                                  ''),
        \ '^#\s*',              '',                                  ''),
        \ '^\s\+',              '\=repeat("-",strlen(submatch(0)))', '')
  if foldtext == ""
    return getline(v:foldstart)
  endif
  return foldtext
endfunction

