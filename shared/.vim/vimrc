"STATUSLINE {{{
function! StatusLineMod()
  if &modified
    return "%#StatusLineModified#(Modified)%##"
  endif
  if &readonly
    return "%#StatusLineReadOnly#(ReadOnly)%##"
  endif
  return ""
endfunction
function! StatusLineBranch()
  :silent let branch = system("git -C " . expand("%:p:h") . " branch --show-current 2> /dev/null | tr -d '\n'")
  if branch == ""
    return ""
  endif
  let highlight = ""
  if branch == "master" || branch == "main"
    let highlight = "%#StatusLineMaster#"
  endif
  return highlight . "(" . branch . ")%##"
endfunction
function! StatusLineFileType()
  if &filetype == ""
    return ""
  endif
  return "(" . &filetype . ")"
endfunction
function! StatusLineFile()
  let file = expand("%")
  if file == ""
    return ""
  endif
  return "(" . file . ")"
endfunction
set statusline=%{%StatusLineFile()%}%=
set statusline+=%{%StatusLineMod()%}
set statusline+=%{%StatusLineBranch()%}
"set statusline+=%{%StatusLineFileType()%}
"}}}

