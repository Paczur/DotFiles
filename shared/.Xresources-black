Xft.dpi:        96

Xft.antialias:  true
Xft.rgba:       rgb
Xft.hinting:    true
Xft.hintstyle:  hintfull
Xft.autohint:   false
Xft.lcdfilter:  lcddefault

*geometry: 400x400
*font: -misc-custom-medium-r-normal--24-240-72-72-c-100-iso10646-1
*boldFont:
*italicFont:
*savelines: 16384
*ScrollBar: false
*scrollBar: false
*termName: rxvt-unicode
*BellIsUrgent: true
*urgentOnBell: true
*cursorBlink: true
*scrollTtyOutput: false
*scrollWithBuffer: true
*scrollTtyKeypress: true

*.cursorColor: #f3f3f3
*.pointerColor: #f3f3f3
*.foreground: #ffffff
*.background: #000000
