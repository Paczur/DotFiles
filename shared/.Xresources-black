!red
*.color1:  #f36e6e
*.color9:  #f36e6e
!green
*.color2:  #6ef36e
*.color10: #6ef36e
!yellow
*.color3:  #f3f36e
*.color11: #f3f36e
!blue
*.color4:  #f3f36e
*.color12: #f3f36e
!cyan
*.color5:  #6ef36e
