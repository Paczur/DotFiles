if [ -z "${RUN_ENV}" ]; then
  export RUN_ENV="/home/paczur/Git/DotFiles/.renv"
  export PATH="${PATH}:${RUN_ENV}"
fi
close() {
  if [ -n "${RUN_ENV}" ]; then
    run
    export PATH="$(echo "$PATH" | sed "s/$(echo ":${RUN_ENV}" | sed 's/\//\\\//g')//g")"
    export RUN_ENV=""
  fi
  unset -f close
}
